# Twilio — SMS & WhatsApp bulletins
# Leave unset to disable external notifications (app still works without these)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Phone number to send SMS FROM (must be a Twilio number, e.g. +15551234567)
TWILIO_SMS_FROM=+15551234567

# Phone number to send WhatsApp FROM
# For sandbox testing: +14155238886 (recipients must join the sandbox first)
# For production: your approved WhatsApp Business number
TWILIO_WHATSAPP_FROM=+14155238886

# Comma-separated recipient phone numbers (international format, e.g. +2348012345678)
NOTIFY_PHONES=+2348012345678,+447700900000
